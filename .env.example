# Copy to .env and fill in.

# PostgreSQL connection string.
# - usectl provides this automatically via its managed Postgres addon.
# - Locally, run Postgres (Docker example below) or use a free hosted Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# Admin panel password
ADMIN_PASSWORD="change-me"

# Long random string for signing admin sessions
AUTH_SECRET="generate-a-long-random-string"

# Quick local Postgres with Docker:
#   docker run --name cleanhub-pg -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=cleanhub -p 5432:5432 -d postgres:16
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cleanhub"
