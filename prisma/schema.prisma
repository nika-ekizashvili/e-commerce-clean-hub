// Clean Hub — data model
// Postgres is used everywhere (usectl provides a managed PostgreSQL addon).
// For local development, point DATABASE_URL at a local/Docker Postgres or a
// free hosted Postgres. See README.md.

generator client {
  provider      = "prisma-client-js"
  // Cover the local machine plus common Linux container images so the
  // Prisma query engine is present after deploy.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  // slug is the stable key used in URLs and seeding
  slug      String    @unique
  // nameKa = Georgian display name
  nameKa    String
  emoji     String?
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleKa     String
  descriptionKa String  @default("")
  // free-text specifications, one per line (e.g. "წონა: 150გ")
  specsKa     String   @default("")
  // price in GEL
  price       Float
  imageUrl    String   @default("")
  inStock     Boolean  @default(true)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
